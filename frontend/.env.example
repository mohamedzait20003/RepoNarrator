# ─────────────────────────────────────────────────────────────────────────────
# CodeAtlas — Frontend (TanStack Start + Vite)
# Copy to `frontend/.env` and adjust as needed. Only VITE_-prefixed vars are
# exposed to the browser bundle — never put secrets here.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the backend API, including the global /api/v1 prefix.
VITE_BASE_URL=http://localhost:4000/api/v1
